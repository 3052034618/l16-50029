# Server
PORT=3000
NODE_ENV=development

# Elasticsearch
ES_NODE=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=changeme
ES_PRODUCT_INDEX=products
ES_SEARCH_LOG_INDEX=search_logs
ES_HOTWORDS_INDEX=hotwords

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Search Settings
HOTWORDS_TOP_N=20
HOTWORDS_WINDOW_HOURS=24
MAX_SEARCH_RESULTS=100
DEFAULT_PAGE_SIZE=20

# Analysis Settings
LOW_CLICK_RATE_THRESHOLD=0.1
HIGH_CLICK_WORD_MIN_COUNT=100

# Logging
LOG_LEVEL=info
